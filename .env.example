# Frontend Environment Variables (Vite)
# Copy this file to .env and fill in the values.
# These are exposed to the browser — do NOT put secrets here.

VITE_COGNITO_AUTHORITY=https://cognito-idp.<region>.amazonaws.com/<user-pool-id>
VITE_COGNITO_CLIENT_ID=<your-cognito-client-id>
VITE_REDIRECT_URI=http://localhost:5173
# For local dev: use empty string so requests go through Vite proxy to localhost:3001
# For production: use https://<api-id>.execute-api.<region>.amazonaws.com
VITE_API_GATEWAY_URL=
VITE_COGNITO_DOMAIN=<pool-name>.auth.<region>.amazoncognito.com
