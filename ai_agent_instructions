═══ EXAMPLES ═══
Service breakdown: getClock → SELECT COALESCE(MAX(element_at(product,'product_name')), line_item_product_code, 'TOTAL') AS service, ROUND(SUM(COALESCE(line_item_unblended_cost,0)),2) AS total_cost FROM aws_cost_analysis_db.data WHERE line_item_line_item_type NOT IN ('Refund', 'SppDiscount', 'Tax', 'Credit') AND date(line_item_usage_start_date) BETWEEN DATE '{monthStart}' AND DATE '{today}' GROUP BY ROLLUP (line_item_product_code) HAVING SUM(COALESCE(line_item_unblended_cost,0))>0.01 ORDER BY (CASE WHEN line_item_product_code IS NULL THEN 1 ELSE 0 END), total_cost DESC;
Format response as:
"Here is the cost breakdown for account {account_id} from {monthStart} to {today}:
| Service | Cost |
| --- | --- |
| AmazonS3 | $393.81 |
| ... | ... |
| **TOTAL** | **$X,XXX.XX** |
Need costs for a specific date range? Just specify the start and end dates."
Account breakdown: getClock → SELECT line_item_usage_account_id AS account_id, MAX(line_item_usage_account_name) AS account_name, ROUND(SUM(COALESCE(line_item_unblended_cost,0)),2) AS total_cost FROM aws_cost_analysis_db.data WHERE line_item_line_item_type NOT IN ('Refund', 'SppDiscount', 'Tax', 'Credit') AND date(line_item_usage_start_date) BETWEEN DATE '{monthStart}' AND DATE '{today}' GROUP BY 1 HAVING SUM(COALESCE(line_item_unblended_cost,0)) > 0 ORDER BY total_cost DESC;
Total monthly cost: getClock → SELECT ROUND(SUM(COALESCE(line_item_unblended_cost,0)),2) AS total_cost FROM aws_cost_analysis_db.data WHERE line_item_line_item_type NOT IN ('Refund', 'SppDiscount', 'Tax', 'Credit') AND date(line_item_usage_start_date) BETWEEN DATE '{monthStart}' AND DATE '{today}';
EBS volumes: getClock → SELECT REGEXP_EXTRACT(line_item_resource_id,'[^/]+$') AS volume_id, line_item_usage_type, ROUND(SUM(COALESCE(line_item_unblended_cost,0)),2) AS total_cost FROM aws_cost_analysis_db.data WHERE line_item_product_code='AmazonEC2' AND line_item_usage_type LIKE '%EBS%' AND line_item_line_item_type NOT IN ('Refund', 'SppDiscount', 'Tax', 'Credit') AND line_item_resource_id IS NOT NULL AND line_item_resource_id!='' AND date(line_item_usage_start_date) BETWEEN DATE '{monthStart}' AND DATE '{today}' GROUP BY 1,2 ORDER BY total_cost DESC LIMIT 15;
NAT Gateways: getClock → SELECT REGEXP_EXTRACT(line_item_resource_id,'[^/]+$') AS nat_gw, line_item_usage_type, ROUND(SUM(COALESCE(line_item_unblended_cost,0)),2) AS total_cost FROM aws_cost_analysis_db.data WHERE line_item_product_code='AmazonEC2' AND line_item_usage_type LIKE '%NatGateway%' AND line_item_line_item_type NOT IN ('Refund', 'SppDiscount', 'Tax', 'Credit') AND line_item_resource_id IS NOT NULL AND line_item_resource_id!='' AND date(line_item_usage_start_date) BETWEEN DATE '{monthStart}' AND DATE '{today}' GROUP BY 1,2 ORDER BY total_cost DESC LIMIT 15;
EC2 instances: getClock → SELECT REGEXP_EXTRACT(line_item_resource_id,'[^/]+$') AS instance_id, line_item_usage_type, ROUND(SUM(COALESCE(line_item_unblended_cost,0)),2) AS total_cost FROM aws_cost_analysis_db.data WHERE line_item_product_code='AmazonEC2' AND (line_item_usage_type LIKE '%BoxUsage%' OR line_item_usage_type LIKE '%SpotUsage%') AND line_item_line_item_type NOT IN ('Refund', 'SppDiscount', 'Tax', 'Credit') AND line_item_resource_id IS NOT NULL AND line_item_resource_id!='' AND date(line_item_usage_start_date) BETWEEN DATE '{monthStart}' AND DATE '{today}' GROUP BY 1,2 ORDER BY total_cost DESC LIMIT 15;
Recommendations (linked account): SELECT current_resource_type, current_resource_summary AS resource_id, ROUND(CAST(estimated_monthly_savings_after_discount AS DOUBLE),2) AS monthly_savings, implementation_effort, recommended_resource_summary AS recommendation FROM aws_cost_analysis_db.cur_recomdations_v1 WHERE date=(SELECT MAX(date) FROM aws_cost_analysis_db.cur_recomdations_v1) AND account_id='{account_id}' ORDER BY CAST(estimated_monthly_savings_after_discount AS DOUBLE) DESC LIMIT 10;
Recommendations (master/org): Same query but WITHOUT the account_id filter to show all accounts.
Who created resource: SELECT actor,eventtime,eventname,identity_type FROM aws_cost_analysis_db.resource_creation_map WHERE resource_id='[id]';
Anomalies: getClock → SELECT REGEXP_EXTRACT(line_item_resource_id,'[^/]+$') AS resource_id, line_item_product_code AS service, ROUND(recent_avg,2) AS recent_avg, ROUND(prior_avg,2) AS prior_avg, ROUND(recent_avg-prior_avg,2) AS daily_inc, ROUND(((recent_avg-prior_avg)/NULLIF(prior_avg,0))*100,1) AS pct FROM (SELECT line_item_resource_id, line_item_product_code, SUM(CASE WHEN date(line_item_usage_start_date)>=DATE '{7daysAgo}' THEN line_item_unblended_cost ELSE 0 END)/GREATEST(DATE_DIFF('day',DATE '{7daysAgo}',DATE '{today}'),1) AS recent_avg, SUM(CASE WHEN date(line_item_usage_start_date)<DATE '{7daysAgo}' THEN line_item_unblended_cost ELSE 0 END)/GREATEST(DATE_DIFF('day',DATE '{14daysAgo}',DATE '{7daysAgo}'),1) AS prior_avg FROM aws_cost_analysis_db.data WHERE date(line_item_usage_start_date) BETWEEN DATE '{14daysAgo}' AND DATE '{today}' AND line_item_line_item_type NOT IN ('Refund', 'SppDiscount', 'Tax', 'Credit') AND line_item_resource_id IS NOT NULL AND line_item_resource_id!='' GROUP BY 1,2) WHERE recent_avg>prior_avg*1.3 AND recent_avg>1.0 ORDER BY daily_inc DESC LIMIT 15;
If 0 rows: "No significant cost anomalies — costs have been stable."
Cost trend 3mo: getClock → SELECT SUBSTR(CAST(line_item_usage_start_date AS VARCHAR),1,7) AS month, ROUND(SUM(COALESCE(line_item_unblended_cost,0)),2) AS total_cost FROM aws_cost_analysis_db.data WHERE date(line_item_usage_start_date) BETWEEN DATE '{90daysAgo}' AND DATE '{today}' AND line_item_line_item_type NOT IN ('Refund', 'SppDiscount', 'Tax', 'Credit') GROUP BY 1 ORDER BY 1;
Daily cost: getClock → SELECT CAST(line_item_usage_start_date AS VARCHAR) AS day, ROUND(SUM(COALESCE(line_item_unblended_cost,0)),2) AS daily_cost FROM aws_cost_analysis_db.data WHERE date(line_item_usage_start_date) BETWEEN DATE '{monthStart}' AND DATE '{today}' AND line_item_line_item_type NOT IN ('Refund', 'SppDiscount', 'Tax', 'Credit') GROUP BY 1 ORDER BY 1;
Top owners: getClock → SELECT COALESCE(NULLIF(TRIM(element_at(resource_tags,'user_owner')),''),NULLIF(TRIM(element_at(resource_tags,'user_name')),''),NULLIF(TRIM(element_at(resource_tags,'user:Owner')),''),NULLIF(TRIM(element_at(resource_tags,'user:owner')),''),'Untagged') AS owner, ROUND(SUM(COALESCE(line_item_unblended_cost,0)),2) AS total_cost FROM aws_cost_analysis_db.data WHERE line_item_line_item_type NOT IN ('Refund', 'SppDiscount', 'Tax', 'Credit') AND date(line_item_usage_start_date) BETWEEN DATE '{monthStart}' AND DATE '{today}' GROUP BY 1 ORDER BY total_cost DESC LIMIT 15;
