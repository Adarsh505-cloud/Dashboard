# AWS Configuration
AWS_REGION=us-east-1

# Server Configuration
PORT=3001
NODE_ENV=development

# Auth bypass for local development (set to 'true' to skip Cognito JWT verification)
SKIP_AUTH=true

# CORS Configuration
FRONTEND_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Athena & CUR config
ATHENA_DATABASE=aws_cost_analysis_db
ATHENA_CUR_TABLE=data
ATHENA_WORKGROUP=primary

# Cognito
COGNITO_USER_POOL_ID=xxxxxxxxxxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxx

# Bedrock Agent
BEDROCK_AGENT_ID=2MRTKZ0BS6
BEDROCK_AGENT_ALIAS_ID=AAT8YZEOOK
BEDROCK_REGION=us-west-2
#BEDROCK_CROSS_ACCOUNT_ROLE_ARN=arn:aws:iam::xxxxxxxxx:role/CrossAccountBedrockAgentRole 
BEDROCK_INVOKE_ROLE_ARN=arn:aws:iam::xxxxxxxxx:role/CostDashboardLambdaRole

HEAVY_LAMBDA_FUNCTION_NAME =resource-fetcher-lambda


